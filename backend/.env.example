# ============================================
# Bantu Mereka — Environment Configuration
# ============================================
# Copy file ini menjadi .env dan isi nilainya
# JANGAN commit .env ke GitHub!

# ── App ────────────────────────────────────
APP_NAME="Bantu Mereka API"
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# ── Server ─────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── MongoDB ────────────────────────────────
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=bantumereka

# ── JWT Auth ───────────────────────────────
JWT_SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── Midtrans ───────────────────────────────
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxx
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_MERCHANT_ID=G000000000

# ── Email (Resend) ─────────────────────────
RESEND_API_KEY=re_xxxxxxxx
EMAIL_FROM=noreply@bantumereka.org
EMAIL_FROM_NAME=Bantu Mereka

# ── reCAPTCHA ──────────────────────────────
RECAPTCHA_SITE_KEY=6LeIxAcTAAAAAJcZVRqyHh71UMIEGNQ_MXjiZKhI
RECAPTCHA_SECRET_KEY=6LeIxAcTAAAAAGG-vFI1TnRWxMZNFuojJ4WifJWe

# ── Object Storage (S3-compatible) ─────────
STORAGE_ENDPOINT=https://sgp1.digitaloceanspaces.com
STORAGE_ACCESS_KEY=your-access-key
STORAGE_SECRET_KEY=your-secret-key
STORAGE_BUCKET=bantumereka-uploads
STORAGE_REGION=sgp1
STORAGE_CDN_URL=https://cdn.bantumereka.org

# ── Sentry ─────────────────────────────────
SENTRY_DSN=

# ── CORS ───────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Frontend URL (untuk redirect/link) ─────
FRONTEND_URL=http://localhost:5173
